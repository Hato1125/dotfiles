{
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "vim_mode": true,
  "cursor_blink": false,
  "show_edit_predictions": false,
  "autosave": "on_focus_change",
  "restore_on_startup": "last_workspace",
  "buffer_font_family": "Comic Mono",
  "buffer_font_size": 13.0,
  "buffer_font_weight": 700.0,
  "buffer_line_height": {
    "custom": 1.2
  },
  "ui_font_family": "Comic Mono",
  "ui_font_size": 14,
  "ui_font_weight": 600,
  "tab_size": 2,
  "format_on_save": "off",
  "lsp_highlight_debounce": 50,
  "agent": {
    "use_modifier_to_send": true,
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gemini-3-pro-preview"
    },
    "play_sound_when_agent_done": true
  },
  "notification_panel": {
    "button": false
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "tabs": {
    "file_icons": true
  },
  "git": {
    "git_gutter": "hide",
    "inline_blame": {
      "enabled": false
    }
  },
  "icon_theme": "Zed (Default)",
  "theme": {
    "mode": "system",
    "light": "GitHub Pitch Light",
    "dark": "GitHub Pitch Dark"
  },
  "terminal": {
    "button": false,
    "font_family": "Comic Mono",
    "font_size": 12,
    "font_weight": 600,
    "line_height": "standard",
    "toolbar": {
      "breadcrumbs": false
    }
  },
  "languages": {
    "Rust": {
      "tab_size": 4
    },
    "Zig": {
      "tab_size": 4
    }
  },
  "file_scan_exclusions": [
    "**/node_modules",
    "**/.git",
    "**/.cache",
    "**/.zig-cache",
    "**/zig-out",
    "**/__pycache__"
  ],
  "auto_install_extensions": {
    "html": true,
    "toml": true,
    "ini": true,
    "make": true,
    "meson": true,
    "neocmake": true,
    "dockerfile": true,
    "zig": true,
    "dart": true,
    "sql": true,
    "angular": true
  }
}
